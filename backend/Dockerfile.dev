# Backend development Dockerfile
# Uses --reload for hot-reload on every Python file save
FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --extra dev --no-install-project

COPY app ./app

EXPOSE 8000

# Hot-reload mode — source is bind-mounted by docker compose watch
CMD ["uv", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "/app/app", "--reload-include", "*.py", "--reload-include", "*.md", "--reload-include", "*.yaml", "--reload-include", "*.yml"]
