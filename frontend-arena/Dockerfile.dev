# Frontend development Dockerfile
# Runs Vite dev server directly (with HMR) instead of building + nginx
FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

EXPOSE 5173

# Source is bind-mounted by docker compose watch; Vite picks up changes via HMR
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
